{
  "name": "ElectroMonkey 控制面板",
  "version": "1.0.0",
  "description": "ElectroMonkey 控制面板：状态浮标、插件管理、快捷键面板",
  "author": "ElectroMonkey",
  "match": ["*://localhost/*", "*://*/*"],
  "exclude": [],
  "runAt": "document-idle",
  "renderer": "renderer.js",
  "css": "style.css",
  "main": null,
  "grant": ["GM_addStyle", "GM_setValue", "GM_getValue", "GM_notification", "GM_log"],
  "enabled": true
}
